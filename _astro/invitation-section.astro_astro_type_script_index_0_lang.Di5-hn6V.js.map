  import gsap from 'gsap';
  import SplitText from 'gsap/SplitText';
  import { setupEntranceObserver } from '@lib/animations/intersection-observer';

  gsap.registerPlugin(SplitText);

  class InvitationSectionElement extends HTMLElement {
    private observerCleanup: (() => void) | null = null;

    connectedCallback() {
      this.observerCleanup = setupEntranceObserver(
        this,
        () => this.playEntranceAnimation(),
        () => this.querySelector('[data-invitation-section]'),
        { threshold: 0.5 }
      );
    }

    disconnectedCallback() {
      this.observerCleanup?.();
    }

    private playEntranceAnimation() {
      const title = this.querySelector('.invitationTitle');
      const description = this.querySelector('.invitationDescription');

      const tl = gsap.timeline({ defaults: { ease: 'power2.out' } });

      // 1. Animate title with SplitText
      if (title) {
        const split = SplitText.create(title, { type: 'words,chars' });
        gsap.set(title, { opacity: 1 });
        gsap.set(split.chars, { opacity: 0, filter: 'blur(20px)' });

        tl.to(split.chars, {
          opacity: 1,
          filter: 'blur(0px)',
          duration: 0.6,
          stagger: 0.03,
        });
      }

      // 2. Animate description
      if (description) {
        gsap.set(description, { y: 15 });
        tl.to(
          description,
          {
            opacity: 0.7,
            y: 0,
            duration: 0.6,
          },
          '-=0.3'
        );
      }
    }
  }

  customElements.define('invitation-section-element', InvitationSectionElement);


