  import app from '../../firebase';
  import { getStorage, ref, uploadBytesResumable, getDownloadURL } from 'firebase/storage';

  import { sessionKeys } from '@utils/constants';

  class FileUpload extends HTMLElement {
    constructor() {
      super();

      const input = document.getElementById('dropzone-file') as HTMLInputElement;
      const fileName = document.getElementById('file-name') as HTMLParagraphElement;

      input?.addEventListener('change', () => {
        const curFiles = input.files;
        if (curFiles && curFiles?.length > 0) {
          const file = curFiles[0];

          // Validate file type before proceeding
          if (!this.isValidPDFFile(file)) {
            this.presentError('Please select a valid PDF file');
            input.value = ''; // Clear the input
            fileName.textContent = 'Drag and drop or browse';
            return;
          }

          fileName.textContent = file.name;
          this.uploadFile(file);
        } else {
          fileName.textContent = 'Click to upload or drag and drop a PDF';
        }
      });
    }

    isValidPDFFile(file: File): boolean {
      const fileName = file.name.toLowerCase();
      const hasValidExtension = fileName.endsWith('.pdf');

      const hasValidMimeType = file.type === 'application/pdf';

      return hasValidExtension && hasValidMimeType;
    }

    uploadFile(file: File) {
      this.clearError();

      const storage = getStorage(app);
      const storageRef = ref(storage, 'startupDecks/' + `${new Date().toISOString()}-${file.name}`);
      const uploadTask = uploadBytesResumable(storageRef, file, { contentType: 'application/pdf' });
      const progressElement = document.getElementById('progress') as HTMLSpanElement;
      const progressTextElement = document.getElementById('progress-text') as HTMLSpanElement;

      // Listen for state changes, errors, and completion of the upload.
      uploadTask.on(
        'state_changed',
        (snapshot) => {
          const input = document.getElementById('dropzone-file') as HTMLInputElement;
          input.setAttribute('upload-state', 'uploading');
          // Get task progress, including the number of bytes uploaded and the total number of bytes to be uploaded
          const progress = (snapshot.bytesTransferred / snapshot.totalBytes) * 100;
          requestAnimationFrame(() => {
            progressElement.style.transform = `scaleX(${progress / 100})`;
            progressTextElement.textContent = `${progress.toFixed(0)}%`;
          });
        },
        (error) => {
          const input = document.getElementById('dropzone-file') as HTMLInputElement;
          input.setAttribute('upload-state', 'unstarted');
          const fileName = document.getElementById('file-name') as HTMLParagraphElement;
          fileName.textContent = 'Click to upload or drag and drop a PDF';
          progressTextElement.textContent = '';
          progressElement.style.transform = 'scaleX(0)';
          // A full list of error codes is available at
          // https://firebase.google.com/docs/storage/web/handle-errors
          switch (error.code) {
            case 'storage/unauthorized':
              this.presentError('Firebase Error: Unauthorized');
              // User doesn't have permission to access the object
              break;
            case 'storage/canceled':
              // User canceled the upload
              break;
            case 'storage/unknown':
              // Unknown error occurred, inspect error.serverResponse
              break;
          }
        },
        () => {
          // Upload completed successfully, now we can get the download URL
          getDownloadURL(uploadTask.snapshot.ref).then((downloadURL) => {
            sessionStorage.setItem(sessionKeys.pitchDeck, downloadURL);
            const input = document.getElementById('dropzone-file') as HTMLInputElement;
            input.setAttribute('upload-state', 'complete');
            this.clearError();
          });
        },
      );
    }

    presentError(error: string) {
      const input = document.getElementById('dropzone-file') as HTMLInputElement;
      const name = input.getAttribute('name');
      const errorElement = document.querySelector(`[data-error-for=${name}]`) as HTMLDivElement;
      const textElement = errorElement.querySelector('span') as HTMLSpanElement;
      textElement.textContent = error;
      errorElement.classList.remove('opacity-0');
    }

    clearError() {
      const input = document.getElementById('dropzone-file') as HTMLInputElement;
      const name = input.getAttribute('name');
      const errorElement = document.querySelector(`[data-error-for=${name}]`) as HTMLDivElement;
      const textElement = errorElement.querySelector('span') as HTMLSpanElement;
      textElement.textContent = '';
      errorElement.classList.add('opacity-0');
    }
  }

  customElements.define('file-upload', FileUpload);


