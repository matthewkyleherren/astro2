  import captureException from '@utils/capture-exception';
  import { sessionKeys } from '@utils/constants';
  import outputEnvInfo from '@utils/dev';
  import { getStartupEndpoint } from '@utils/endpoint';
  import type { WebsiteStartupSubmission } from '@sequel/types';
  import type SequelNotification from 'src/custom-elements/custom-notification';

  outputEnvInfo();

  const defaultFieldNames = [
    'oneliner',
    'startupName',
    'contactEmail',
    'contactNumber',
    'amountRaising',
    'source',
    'deck',
  ];

  customElements.define(
    'submit-form',
    class SubmitForm extends HTMLElement {
      constructor() {
        super();
        const form = this.querySelector('form') as HTMLFormElement;

        if (form) {
          form.addEventListener('submit', (e) => {
            e.preventDefault();

            const hasLeadInvestor = form.querySelector(
              'input[name=hasLeadInvestor]',
            ) as HTMLInputElement;

            const { founderFields } = this.getFounders(form);
            const fieldNames = [...defaultFieldNames, ...founderFields];
            if (hasLeadInvestor.checked) {
              fieldNames.push('leadInvestor');
            }

            const fields = fieldNames.map((name) => {
              return form.querySelector(`[name=${name}]`) as HTMLInputElement;
            });

            const invalidFields = fields.map((f) => this.checkValidity(f, form)).filter(Boolean);
            if (invalidFields.length > 0) {
              invalidFields?.[0]?.focus();
              return;
            }

            const submitData = this.prepareData(form);
            sessionStorage.setItem(sessionKeys.startupSubmit, JSON.stringify(submitData));
            this.postData(submitData);
          });
        }
      }

      getFounders(form: HTMLFormElement) {
        const formData = new FormData(form);
        const get = (name: string): string => formData.get(name) as string;

        const founders = [];
        const founderFields = [];
        let i = 1;

        do {
          founders.push({
            firstName: get(`founderFirstName${i}`),
            lastName: get(`founderLastName${i}`),
            linkedIn: {
              url: get(`founderUrl${i}`),
            },
          });
          founderFields.push(`founderFirstName${i}`, `founderLastName${i}`, `founderUrl${i}`);
          i++;
        } while (
          formData.has(`founderFirstName${i}`) &&
          formData.has(`founderLastName${i}`) &&
          formData.has(`founderUrl${i}`)
        );
        return { founders, founderFields };
      }

      checkValidity(field: HTMLInputElement, form: HTMLFormElement) {
        let isValid = field.validity.valid;

        if (field.name === 'deck') {
          const uploadState = field.getAttribute('upload-state');
          if (uploadState === 'uploading') {
            isValid = false;
            field.setCustomValidity('Please wait for the upload to finish');
          }
          if (uploadState === 'complete') {
            isValid = true;
            field.setCustomValidity('');
          }
        }
        if (!isValid) {
          field.classList.add('border-red-600');
          const errorElement = form.querySelector(`[data-error-for=${field.name}]`);
          const errorText = form.querySelector(`[data-error-for=${field.name}] span`);
          if (errorElement) {
            errorElement.classList.remove('opacity-0');
          }
          if (errorText) errorText.textContent = field.validationMessage;
          return field;
        }
      }

      getAreas(form: HTMLFormElement) {
        const checkboxes = form.querySelectorAll(
          'input[type=checkbox]',
        ) as NodeListOf<HTMLInputElement>;

        return Array.from(checkboxes)
          .filter((checkbox) => checkbox.checked)
          .filter((checkbox) => checkbox.id !== 'none')
          .map((checkbox) => checkbox.id);
      }

      prepareData(form: HTMLFormElement): WebsiteStartupSubmission {
        const formData = new FormData(form);
        const get = (name: string): string => formData.get(name) as string;
        const pitchDeck = sessionStorage.getItem(sessionKeys.pitchDeck) ?? '';
        const { founders } = this.getFounders(form);
        const url = new URLSearchParams(window.location.search);
        let channel = "website";
        if (url.has('source'))
        {
          channel += `.${url.get('source')}`
        }

        return {
          contactEmail: get('contactEmail'),
          contactNumber: get('contactNumber'),
          startupName: get('startupName'),
          oneliner: get('oneliner'),
          founders,
          areas: this.getAreas(form),
          source: {
            channel,
            text: get('source'),
          },
          roundInfo: {
            amountRaising: parseInt(get('amountRaising').replace(/[^0-9]/g, ''), 10),
            leadInvestor: formData.has('hasLeadInvestor') ? get('leadInvestor') : '',
            stage: get('stage'),
            pitchDeck,
          },
        };
      }

      postData(data: WebsiteStartupSubmission) {
        const url = `${getStartupEndpoint()}/website-startupSubmit`;
        this.showLoader();
        fetch(url, {
          method: 'POST',
          body: JSON.stringify(data),
          headers: {
            'Content-Type': 'application/json',
          },
        })
          .then((result) => {
            console.log(result);
            window.location.href = '/founders/complete';
          })
          .catch((error) => {
            this.hideLoader();
            const notification = document.querySelector(
              'custom-notification',
            ) as SequelNotification;
            notification.show('Something went wrong. Please try again.');

            captureException(error);
          });
      }

      showLoader() {
        const loader = this.querySelector('#loader') as HTMLDivElement;
        const button = this.querySelector('button[type="submit"]') as HTMLSpanElement;
        loader.classList.remove('hidden');
        button.classList.add('hidden');
      }

      hideLoader() {
        const loader = this.querySelector('#loader') as HTMLDivElement;
        const button = this.querySelector('button[type="submit"]') as HTMLSpanElement;
        loader.classList.add('hidden');
        button.classList.remove('hidden');
      }
    },
  );


