{"version":3,"file":"Clock.astro_astro_type_script_index_0_lang.BLvD1VJ4.js","sources":["../../../src/components/atoms/Clock.astro?astro&type=script&index=0&lang.ts"],"sourcesContent":["  function initClocks() {\n    const clocks = document.querySelectorAll('[data-clock]');\n\n    clocks.forEach((clock) => {\n      const timezoneAttr = clock.getAttribute('data-timezone');\n      if (!timezoneAttr) return;\n\n      const timezone: string = timezoneAttr;\n\n      const hourHand = clock.querySelector('[data-hour-hand]') as SVGLineElement;\n      const minuteHand = clock.querySelector('[data-minute-hand]') as SVGLineElement;\n      const secondHand = clock.querySelector('[data-second-hand]') as SVGLineElement;\n\n      if (!hourHand || !minuteHand || !secondHand) return;\n\n      // Cache the formatter - created once instead of 60 times per second\n      const formatter = new Intl.DateTimeFormat('en-US', {\n        timeZone: timezone,\n        hour: 'numeric',\n        minute: 'numeric',\n        second: 'numeric',\n        hour12: false,\n      });\n\n      /**\n       * Syncs the CSS animation to the current timezone time.\n       * Uses negative animation-delay to start the animation at the correct position.\n       * This runs off the main thread after initial sync.\n       */\n      function syncClockToTime() {\n        const now = new Date();\n        const parts = formatter.formatToParts(now);\n        const hours = parseInt(parts.find((p) => p.type === 'hour')?.value || '0', 10);\n        const minutes = parseInt(parts.find((p) => p.type === 'minute')?.value || '0', 10);\n        const seconds = parseInt(parts.find((p) => p.type === 'second')?.value || '0', 10);\n\n        // Calculate total elapsed time for each hand's animation cycle\n        // Second hand: seconds into current minute (0-59)\n        const secondsElapsed = seconds;\n\n        // Minute hand: total seconds into current hour (0-3599)\n        const minuteSecondsElapsed = minutes * 60 + seconds;\n\n        // Hour hand: total seconds into current 12-hour period (0-43199)\n        const hourSecondsElapsed = (hours % 12) * 3600 + minutes * 60 + seconds;\n\n        // Set negative animation-delay to start animation at correct position\n        // This tells CSS \"pretend the animation started N seconds ago\"\n        secondHand.style.animationDelay = `-${secondsElapsed}s`;\n        minuteHand.style.animationDelay = `-${minuteSecondsElapsed}s`;\n        hourHand.style.animationDelay = `-${hourSecondsElapsed}s`;\n      }\n\n      // Initial sync on page load\n      syncClockToTime();\n\n      // Re-sync when tab becomes visible again (prevents drift after tab hidden)\n      document.addEventListener('visibilitychange', () => {\n        if (document.visibilityState === 'visible') {\n          syncClockToTime();\n        }\n      });\n    });\n  }\n\n  // Initialize clocks\n  initClocks();\n\n\n//# sourceMappingURL=data:application/json;charset=utf-8;base64,"],"names":["e","n","initClocks","clock","timezoneAttr","timezone","hourHand","minuteHand","secondHand","formatter","syncClockToTime","now","parts","hours","p","minutes","seconds","secondsElapsed","minuteSecondsElapsed","hourSecondsElapsed"],"mappings":"CA8GE,UAAA,CAAA,GAAA,CAAA,IAAAA,EAAA,OAAA,OAAA,IAAA,OAAA,OAAA,OAAA,IAAA,OAAA,OAAA,WAAA,IAAA,WAAA,OAAA,KAAA,IAAA,KAAA,CAAA,EAAAC,EAAA,IAAAD,EAAA,QAAA,MAAAC,IAAAD,EAAA,gBAAAA,EAAA,iBAAA,CAAA,EAAAA,EAAA,gBAAAC,CAAA,EAAA,uCAAAD,EAAA,yBAAA,mDAAA,MAAA,CAAA,CAAA,GAAA,EAAA,SAASE,GAAa,CACL,SAAS,iBAAiB,cAAc,EAEhD,QAASC,GAAU,CACxB,MAAMC,EAAeD,EAAM,aAAa,eAAe,EACvD,GAAI,CAACC,EAAc,OAEnB,MAAMC,EAAmBD,EAEnBE,EAAWH,EAAM,cAAc,kBAAkB,EACjDI,EAAaJ,EAAM,cAAc,oBAAoB,EACrDK,EAAaL,EAAM,cAAc,oBAAoB,EAE3D,GAAI,CAACG,GAAY,CAACC,GAAc,CAACC,EAAY,OAG7C,MAAMC,EAAY,IAAI,KAAK,eAAe,QAAS,CACjD,SAAUJ,EACV,KAAM,UACN,OAAQ,UACR,OAAQ,UACR,OAAQ,GACT,EAOD,SAASK,GAAkB,CACzB,MAAMC,MAAU,KACVC,EAAQH,EAAU,cAAcE,CAAG,EACnCE,EAAQ,SAASD,EAAM,KAAME,GAAMA,EAAE,OAAS,MAAM,GAAG,OAAS,IAAK,EAAE,EACvEC,EAAU,SAASH,EAA