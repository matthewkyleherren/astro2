  import { sessionKeys } from '@utils/constants';
  import outputEnvInfo from '@utils/dev';
  import { partialSignup, SIGN_UP_HANDLED_ERROR_CODES } from '@backend/auth';
  import type SequelNotification from 'src/custom-elements/custom-notification';
  import type { PartialSignUpInput } from 'src/types/signup';
  import captureException from '@utils/capture-exception';
  import intlTelInput from 'intl-tel-input/intlTelInputWithUtils';

  const successfulPayment = localStorage.getItem(sessionKeys.successfulPayment);

  if (successfulPayment) {
    localStorage.removeItem(sessionKeys.successfulPayment);
  }

  const previousUrl = localStorage.getItem(sessionKeys.previousUrl);

  if (previousUrl) {
    localStorage.removeItem(sessionKeys.previousUrl);
  }

  outputEnvInfo();

  const fieldNames = ['firstName', 'lastName', 'preferredName', 'email', 'contactNumber', 'countryOfResidence'];

  const contactNumber = document.querySelector('#contactNumber') as HTMLInputElement;

  const options = {
    initialCountry: 'auto',
    geoIpLookup: (callback: (iso2: any) => void) => {
      fetch('https://ipapi.co/json')
        .then(function (res) {
          return res.json();
        })
        .then(function (data) {
          callback(data.country_code);
        })
        .catch(function () {
          callback('us');
        });
    },
    separateDialCode: false,
  };

  const iti = intlTelInput(contactNumber, options as any);

  if (contactNumber.parentNode) {
    const dialCodeElement = contactNumber.parentNode.querySelector('.iti__selected-dial-code');
    if (dialCodeElement instanceof HTMLElement) {
      dialCodeElement.style.color = '#ffffff';
    }
  }

  customElements.define(
    'signup-form',
    class SignupForm extends HTMLElement {
      constructor() {
        super();
        const form = this.querySelector('form') as HTMLFormElement;

        const sessionData = JSON.parse(localStorage.getItem(sessionKeys.join) || '{}');
        const phoneNumber = localStorage.getItem(sessionKeys.phoneNumber);

        // Enable all fields
        for (const name of fieldNames) {
          const field = form.querySelector(`[name=${name}]`);
          if (field instanceof HTMLInputElement && field.disabled) {
            field.disabled = false;

            // Set the field value from the session data
            if (sessionData[name]) {
              field.value = sessionData[name];
            }
            if (name === 'contactNumber' && phoneNumber) {
              iti.setNumber(phoneNumber);
            }
          }
        }

        const countryButton = form.querySelector('#countryButton') as HTMLButtonElement;
        if (countryButton?.disabled) {
          countryButton.disabled = false;
        }

        // Enable the country selector
        const countrySelector = this.querySelector('button.iti__selected-country');
        if (countrySelector instanceof HTMLButtonElement) {
          countrySelector.disabled = false;
        }

        // Show submit button
        const submitButtonContainer = this.querySelector('#submit-button-container');
        submitButtonContainer?.classList.remove('opacity-0');

        form.addEventListener('submit', async (e) => {
          e.preventDefault();

          const isValid = await this.validateForm(form);
          if (isValid) {
            this.showLoader();
            const data = this.parseData(form);

            if (!data) return;

            try {
              const { id } = await partialSignup(data);

              try {
                localStorage.setItem(sessionKeys.join, JSON.stringify({ ...data, id }));
                localStorage.setItem(sessionKeys.countryOfResidence, data.countryOfResidence);
                localStorage.setItem(sessionKeys.phoneNumber, data.phoneNumber);
                const SEVEN_DAYS = 7 * 24 * 60 * 60;
                document.cookie = `${sessionKeys.join}=${new Date().toISOString()}; path=/; max-age=${SEVEN_DAYS}`;
              } catch (error) {
                console.error('Failed to store session data:', error);
                captureException(error);
                const notification = document.querySelector(
                  'custom-notification',
                ) as SequelNotification;
                notification.show('Failed to save your data. Please try again.');
                return;
              }

              window.location.href = '/join/investment';
            } catch (error) {
              if (error instanceof Error) {
                // Only capture errors with Sentry that are not handled by the UI
                if (!SIGN_UP_HANDLED_ERROR_CODES.includes(error.cause as string)) {
                  captureException(error);
                }
                if (error.cause === 'INVALID_EMAIL') {
                  const field = form.querySelector('[name=email]') as HTMLInputElement;
                  this.showValidationError(field, error.message);
                } else {
                  const notification = document.querySelector(
                    'custom-notification',
                  ) as SequelNotification;
                  notification.show(error.message);
                }
              } else captureException(error);
            } finally {
              this.hideLoader();
            }
          }
        });
      }

      parseData(form: HTMLFormElement): PartialSignUpInput {
        let referralCode: string = form.dataset.referralCode || '';

        return {
          phoneNumber: iti.getNumber(),
          firstName: form.firstName.value.trim(),
          lastName: form.lastName.value.trim(),
          preferredName: form.preferredName.value.trim() || undefined,
          email: form.email.value.trim(),
          referralCode: referralCode.startsWith('i/') ? referralCode.slice(2) : referralCode,
          countryOfResidence: form.countryOfResidence.value,
        };
      }

      showLoader() {
        const loader = this.querySelector('#loader') as HTMLDivElement;
        const button = this.querySelector('button[type="submit"]') as HTMLButtonElement;
        loader.classList.remove('hidden');
        button.classList.add('hidden');
      }

      hideLoader() {
        const loader = this.querySelector('#loader') as HTMLDivElement;
        const button = this.querySelector('button[type="submit"]') as HTMLButtonElement;
        loader.classList.add('hidden');
        button.classList.remove('hidden');
      }

      async validateForm(form: HTMLFormElement) {
        const fields = fieldNames.map((name) => {
          return form.querySelector(`[name=${name}]`) as HTMLInputElement;
        });

        const invalidFields = await Promise.all(fields.map(this.validateField.bind(this))).then(
          (fields) => fields.filter(Boolean),
        );
        if (invalidFields.length > 0) {
          invalidFields[0]?.scrollIntoView({ block: 'center' });
        }
        return invalidFields.length === 0;
      }

      showValidationError(field: HTMLInputElement, errorMessage: string) {
        field.classList.add('border-red-600');
        const errorElement = this.querySelector(`[data-error-for=${field.name}]`);
        const errorText = this.querySelector(`[data-error-for=${field.name}] span`);
        if (errorElement) errorElement.classList.remove('opacity-0');
        if (errorText) errorText.textContent = errorMessage;
      }

      async validateField(field: HTMLInputElement) {
        if (!field.validity.valid) {
          this.showValidationError(field, field.validationMessage);
          return field;
        }
        if (field.name === 'contactNumber') {
          // if the phone input is not loaded, getNumber() will return null
          if (iti.getNumber() === null) {
            this.showLoader();
            // Wait for the phone input to load
            await iti.promise;
            this.hideLoader();
          }
          const isValid = iti.isValidNumber();
          if (!isValid) {
            this.showValidationError(field, 'Your phone number does not appear to be valid');
            return field;
          }
        }
        if (field.name === 'countryOfResidence') {
          if (field.value.length === 0) {
            this.showValidationError(field, 'Please select your country of residence');
            return field;
          }
        }
        if (field.name === 'firstName' || field.name === 'lastName') {
          if (field.value.length > 255) {
            this.showValidationError(field, 'Name must be less than 255 characters');
            return field;
          }

          if (/[<>%$?&]/.test(field.value)) {
            this.showValidationError(field, 'Name can only contain letters and hyphens.');
            return field;
          }
        }
        if (field.name === 'preferredName' && field.value.length > 0) {
          if (field.value.length > 255) {
            this.showValidationError(field, 'Name must be less than 255 characters');
            return field;
          }

          if (/[<>%$?&]/.test(field.value)) {
            this.showValidationError(field, 'Name can only contain letters and hyphens.');
            return field;
          }
        }
        return null;
      }
    },
  );


