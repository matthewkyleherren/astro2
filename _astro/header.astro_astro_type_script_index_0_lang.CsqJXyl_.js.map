    // Create open timeline
    openTimeline = gsap.timeline();

    // 1. Hamburger to X animation
    openTimeline.to(
      menuLine1,
      {
        rotation: 45,
        y: 3.5,
        duration: 0.3,
        ease: 'power2.inOut',
      },
      0,
    );
    openTimeline.to(
      logo,
      {
        opacity: 0,
        duration: 0.3,
        ease: 'power2.inOut',
      },
      0,
    );

    openTimeline.to(
      menuLine2,
      {
        rotation: -45,
        y: -3.5,
        duration: 0.3,
        ease: 'power2.inOut',
      },
      0,
    );

    // 2. Background circle expansion animation
    openTimeline.to(
      menuOverlay,
      {
        clipPath: `circle(200% at ${getButtonClipOrigin()})`,
        duration: 0.5,
        ease: 'power2.in',
      },
      0,
    );

    // 3. Staggered text animation for nav links
    splitTexts.forEach((split, index) => {
      openTimeline!.to(
        split.chars,
        {
          opacity: 1,
          y: 0,
          duration: 0.4,
          stagger: 0.02,
          ease: 'power2.out',
        },
        0.2 + index * 0.08,
      );
    });

    // 4. Mobile clocks fade in
    if (mobileClocks.length > 0) {
      openTimeline.to(
        mobileClocks,
        {
          opacity: 1,
          y: 0,
          duration: 0.6,
          stagger: 0.15,
          ease: 'power2.out',
          onStart: () => {
            startClockAnimation();
          },
        },
        '-=0.6',
      );
    }

    // 4b. Clock titles character animation
    clockTitleSplits.forEach((split, index) => {
      openTimeline!.to(
        split.chars,
        {
          opacity: 1,
          y: 0,
          duration: 0.4,
          stagger: 0.02,
          ease: 'power2.out',
        },
        '<',
      );
    });

    // 5. Clock coordinates scramble animation
    mobileClockCoords.forEach((coords, index) => {
      const targetText = coords.getAttribute('data-coords') || '';
      openTimeline!.to(
        coords,
        {
          duration: 1.5,
          scrambleText: {
            text: targetText,
            chars: '01.,;:!?’"-_/|~`@#$%^&+=<>()[]{}',
            tweenLength: true,
            revealDelay: 0.5,
            speed: 0.3,
          },
        },
        '<',
      );
    });

    // 4c. Clock dividers scale animation (left to right)
    if (mobileClockDividers.length > 0) {
      openTimeline.to(
        mobileClockDividers,
        {
          scaleX: 1,
          duration: 0.5,
          stagger: 0.1,
          ease: 'power2.out',
        },
        '<',
      );
    }

    // 6. Social icons fade in with scale
    if (socialIcons.length > 0) {
      openTimeline.fromTo(
        socialIcons,
        { opacity: 0, scale: 0.95 },
        {
          opacity: 1,
          scale: 1,
          duration: 0.8,
          stagger: 0.07,
          ease: 'back.out(1.5)',
        },
        '-=0.5',
      );
    }

    navLinks[0]?.focus();
  }

  function closeMenu() {
