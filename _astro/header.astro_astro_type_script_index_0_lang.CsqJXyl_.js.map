        if (socialIcons.length > 0) {
          animationLib.set(socialIcons, { opacity: 0, scale: 0.8 });
        }

        // Stop clock animation and reset clocks
        stopClockAnimation();
        if (mobileClocks.length > 0) {
          animationLib.set(mobileClocks, { opacity: 0, y: 20 });
        }
        mobileClockCoords.forEach((coords) => {
          (coords as HTMLElement).textContent = '';
        });

        // Reset clock titles
        clockTitleSplits.forEach((split) => {
          animationLib.set(split.chars, { opacity: 0, y: 30 });
        });

        // Reset clock dividers
        if (mobileClockDividers.length > 0) {
          animationLib.set(mobileClockDividers, { scaleX: 0 });
        }
      },
    });

    // Fade out mobile clocks
    if (mobileClocks.length > 0) {
      closeTimeline.to(
        mobileClocks,
        {
          opacity: 0,
          y: 10,
          duration: 0.5,
          stagger: 0.02,
        },
        0,
      );
    }

    // Fade out clock titles
    clockTitleSplits.forEach((split, index) => {
      closeTimeline!.to(
        split.chars,
        {
          opacity: 0,
          y: -15,
          duration: 0.15,
          stagger: 0.01,
        },
        0.02 + index * 0.02,
      );
    });

    // Scale down clock dividers
    if (mobileClockDividers.length > 0) {
      closeTimeline.to(
        mobileClockDividers,
        {
          scaleX: 0,
          duration: 0.15,
          stagger: 0.02,
        },
        0,
      );
    }

    // Fade out social icons
    if (socialIcons.length > 0) {
      closeTimeline.to(
        socialIcons,
        {
          opacity: 0,
          scale: 0.9,
          duration: 0.15,
          stagger: 0.02,
        },
        0,
      );
    }

    // Fade out nav links
    splitTexts.forEach((split, index) => {
      closeTimeline!.to(
        split.chars,
        {
          opacity: 0,
          y: -15,
          duration: 0.2,
          stagger: 0.01,
        },
        0.05 + index * 0.03,
      );
    });

    // Background circle shrink animation
    closeTimeline.to(
      menuOverlay,
      {
        clipPath: `circle(0% at ${getButtonClipOrigin()})`,
        duration: 0.3,
      },
      0.15,
    );

    // X to hamburger animation
    closeTimeline.to(
      menuLine1,
      {
        rotation: 0,
        y: 0,
        duration: 0.3,
        ease: 'power2.inOut',
      },
      0.2,
    );

    closeTimeline.to(
      menuLine2,
      {
        rotation: 0,
        y: 0,
        duration: 0.3,
        ease: 'power2.inOut',
      },
      0.2,
    );

    closeTimeline.to(
      logo,
      {
        opacity: 1,
        duration: 0.3,
        ease: 'power2.inOut',
      },
      0.2,
    );
  }

  async function toggleMenu() {
    if (isOpen) {
      closeMenu();
    } else {
      await openMenu();
    }
  }

  // Desktop tabs scroll behavior
  function handleScroll() {
    const currentScrollY = window.scrollY;
    const deltaY = currentScrollY - lastScrollY;

    // Update scroll velocity (smoothed)
    scrollVelocity = scrollVelocity * 0.8 + deltaY * 0.2;

    // Determine scroll direction with hysteresis
    if (Math.abs(scrollVelocity) > 2) {
      // Minimum velocity threshold
      if (scrollVelocity > 0 && scrollDirection !== 1) {
        scrollDirection = 1; // Scrolling down
      } else if (scrollVelocity < 0 && scrollDirection !== -1) {
        scrollDirection = -1; // Scrolling up
      }
    } else {
      // Reset direction when scrolling slows down significantly
      resetScrollDirection();
    }

    if (desktopTabs) {
      if (scrollDirection === 1 && isTabsVisible) {
        // Clear any pending timeout
        if (scrollTimeout) {
          clearTimeout(scrollTimeout);
          scrollTimeout = null;
        }

        // Fade out and disable pointer events when scrolling down
        isTabsVisible = false;
        desktopTabs.style.opacity = '0';
        desktopTabs.style.pointerEvents = 'none';
      } else if (scrollDirection === -1 && !isTabsVisible) {
        // Clear any pending timeout
        if (scrollTimeout) {
          clearTimeout(scrollTimeout);
          scrollTimeout = null;
        }

        // Fade in and enable pointer events when scrolling up
        isTabsVisible = true;
        desktopTabs.style.opacity = '1';
        desktopTabs.style.pointerEvents = 'auto';
