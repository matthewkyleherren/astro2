  type GsapType = (typeof import('gsap'))['default'];
  type SplitTextType = (typeof import('gsap/SplitText'))['default'];

  let gsap: GsapType | null = null;
  let SplitText: SplitTextType | null = null;
  let animationLibsPromise: Promise<void> | null = null;

  const ensureAnimationLibs = async () => {
    if (gsap && SplitText) return;
    if (!animationLibsPromise) {
      animationLibsPromise = Promise.all([
        import('gsap'),
        import('gsap/SplitText'),
        import('gsap/ScrambleTextPlugin'),
      ]).then(([gsapModule, splitTextModule, scrambleTextModule]) => {
        gsap = gsapModule.default;
        SplitText = splitTextModule.default;
        gsap.registerPlugin(SplitText, scrambleTextModule.ScrambleTextPlugin);
      });
    }
    await animationLibsPromise;
  };

  const logo = document.getElementById('header-logo');
  const menuButton = document.getElementById('mobile-menu-button');
  const menuOverlay = document.getElementById('mobile-menu-overlay');
  const menuLine1 = document.querySelector('.menu-line-1');
  const menuLine2 = document.querySelector('.menu-line-2');
  const navLinks = Array.from(document.querySelectorAll<HTMLElement>('.mobile-nav-link'));
  const socialIcons = Array.from(document.querySelectorAll<HTMLElement>('.social-icon'));
  const menuFocusableElements = [...navLinks, ...socialIcons];
  const mobileClocks = Array.from(document.querySelectorAll<HTMLElement>('.mobile-clock'));
  const mobileClockCoords = Array.from(
    document.querySelectorAll<HTMLElement>('.mobile-clock-coords'),
  );
  const mobileClockTitles = Array.from(
    document.querySelectorAll<HTMLElement>('.mobile-clock-title'),
  );
  const mobileClockDividers = Array.from(
    document.querySelectorAll<HTMLElement>('.mobile-clock-divider'),
  );
  const desktopTabs = document.getElementById('headerDesktopTabs');

  let isOpen = false;
  let lastScrollY = window.scrollY;
  let isTabsVisible = true;
  let scrollTimeout: number | null = null;
  let directionResetTimeout: number | null = null;
  let scrollDirection = 0; // -1 for up, 1 for down, 0 for stable
  let scrollVelocity = 0;
  let openTimeline: ReturnType<GsapType['timeline']> | null = null;
  let closeTimeline: ReturnType<GsapType['timeline']> | null = null;
  let splitTexts: Array<{ chars: Element[] }> = [];
  let clockTitleSplits: Array<{ chars: Element[] }> = [];
  let clockAnimationId: number | null = null;
  let lastFocusedElement: HTMLElement | null = null;

  // Get the button's center position for clip-path origin
  function getButtonClipOrigin() {
    if (!menuButton) return 'calc(100% - 2rem) 2.5rem';
    const rect = menuButton.getBoundingClientRect();
    const centerX = rect.left + rect.width / 2;
    const centerY = rect.top + rect.height / 2;
    return `${centerX}px ${centerY}px`;
  }

  // Initialize SplitText for nav links and set initial states
  function initSplitText() {
    const animationLib = gsap;
    const splitTextLib = SplitText;
    if (!animationLib || !splitTextLib) return;
    splitTexts = [];
    navLinks.forEach((link) => {
      const split = splitTextLib.create(link, { type: 'chars', mask: 'chars' });
      animationLib.set(split.chars, { opacity: 0, y: 30 });
      splitTexts.push(split);
    });

    // Initialize clock title SplitText
    clockTitleSplits = [];
    mobileClockTitles.forEach((title) => {
      const split = splitTextLib.create(title, { type: 'chars', mask: 'chars' });
      animationLib.set(split.chars, { opacity: 0, y: 30 });
      clockTitleSplits.push(split);
    });

    // Set social icons initial state
    if (socialIcons.length > 0) {
      animationLib.set(socialIcons, { opacity: 0, scale: 0.8 });
    }

    // Initialize mobile clocks (hidden)
    if (mobileClocks.length > 0) {
      animationLib.set(mobileClocks, { opacity: 0, y: 20 });
    }
    mobileClockCoords.forEach((coords) => {
      (coords as HTMLElement).textContent = '';
    });

    // Initialize clock dividers (hidden, scaled from left)
    if (mobileClockDividers.length > 0) {
      animationLib.set(mobileClockDividers, { scaleX: 0, transformOrigin: 'left center' });
    }
  }

  // Clock hand animation functions
  function updateClockHands() {
    mobileClocks.forEach((clock) => {
      const timezone = clock.getAttribute('data-timezone');
      if (!timezone) return;

      const hourHand = clock.querySelector('.mobile-clock-hour') as SVGLineElement;
      const minuteHand = clock.querySelector('.mobile-clock-minute') as SVGLineElement;
      const secondHand = clock.querySelector('.mobile-clock-second') as SVGLineElement;

      if (!hourHand || !minuteHand || !secondHand) return;

      const now = new Date();
      const formatter = new Intl.DateTimeFormat('en-US', {
        timeZone: timezone,
        hour: 'numeric',
        minute: 'numeric',
        second: 'numeric',
        hour12: false,
      });

      const parts = formatter.formatToParts(now);
      const hours = parseInt(parts.find((p) => p.type === 'hour')?.value || '0', 10);
      const minutes = parseInt(parts.find((p) => p.type === 'minute')?.value || '0', 10);
      const seconds = parseInt(parts.find((p) => p.type === 'second')?.value || '0', 10);

      const hourRotation = (hours % 12) * 30 + minutes * 0.5 + seconds * (0.5 / 60);
      const minuteRotation = minutes * 6 + seconds * 0.1;
      const secondRotation = seconds * 6;

      hourHand.style.transform = `rotate(${hourRotation}deg)`;
      minuteHand.style.transform = `rotate(${minuteRotation}deg)`;
      secondHand.style.transform = `rotate(${secondRotation}deg)`;
    });

    clockAnimationId = requestAnimationFrame(updateClockHands);
  }

  function startClockAnimation() {
    if (clockAnimationId === null) {
      updateClockHands();
    }
  }

  function stopClockAnimation() {
    if (clockAnimationId !== null) {
      cancelAnimationFrame(clockAnimationId);
      clockAnimationId = null;
