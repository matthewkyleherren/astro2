  // Initialize
  if (menuButton && menuOverlay) {
    // Set initial clip-path using actual button position
    menuOverlay.style.clipPath = `circle(0% at ${getButtonClipOrigin()})`;

    // Initialize desktop tabs scroll behavior
    if (desktopTabs) {
      desktopTabs.style.pointerEvents = 'auto';
      desktopTabs.style.opacity = '1';
      desktopTabs.style.transition = 'opacity 0.3s ease-out';
    }
    setMenuAccessibilityState(false);
    window.addEventListener('scroll', throttledScroll, { passive: true });

    menuButton.addEventListener('click', toggleMenu);
    document.addEventListener('keydown', (event: KeyboardEvent) => {
      if (event.key === 'Escape' && isOpen) closeMenu();
    });

