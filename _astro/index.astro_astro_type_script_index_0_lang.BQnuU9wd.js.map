  import captureException from '@utils/capture-exception';
  import outputEnvInfo from '@utils/dev';
  import submitFilmClub from '@backend/film-club';
  import type { FilmClubFormData } from '../../types/film-club';
  import type SequelNotification from 'src/custom-elements/custom-notification';

  outputEnvInfo();

  const fieldNames = ['fullName', 'email', 'company', 'role', 'linkedin'];

  customElements.define(
    'film-club-form',
    class FilmClubForm extends HTMLElement {
      constructor() {
        super();
        const form = this.querySelector('form') as HTMLFormElement;

        if (form) {
          form.addEventListener('submit', async (e) => {
            e.preventDefault();

            const fields = fieldNames.map((name) => {
              return form.querySelector(`[name=${name}]`) as HTMLInputElement;
            });

            const invalidFields = fields.map((f) => this.checkValidity(f, form)).filter(Boolean);
            if (invalidFields.length > 0) {
              invalidFields?.[0]?.focus();
              return;
            }

            this.showLoader();
            const submitData = this.prepareData(form);

            try {
              await submitFilmClub(submitData);
              this.showSuccess();
            } catch (error) {
              this.hideLoader();
              const notification = document.querySelector(
                'custom-notification',
              ) as SequelNotification;
              if (error instanceof Error) {
                notification.show(error.message);
              } else {
                notification.show('Something went wrong. Please try again.');
              }
              captureException(error);
            }
          });
        }
      }

      checkValidity(field: HTMLInputElement, form: HTMLFormElement) {
        let isValid = field.validity.valid;

        if (!isValid) {
          field.classList.add('border-red-600');
          const errorElement = form.querySelector(`[data-error-for=${field.name}]`);
          const errorText = form.querySelector(`[data-error-for=${field.name}] span`);
          if (errorElement) {
            errorElement.classList.remove('opacity-0');
          }
          if (errorText) errorText.textContent = field.validationMessage;
          return field;
        }

        // Clear any previous errors
        field.classList.remove('border-red-600');
        const errorElement = form.querySelector(`[data-error-for=${field.name}]`);
        if (errorElement) {
          errorElement.classList.add('opacity-0');
        }

        return null;
      }

      prepareData(form: HTMLFormElement): FilmClubFormData {
        const formData = new FormData(form);
        const interestedInSponsoringCheckbox = form.querySelector('input[name="interestedInSponsoring"]') as HTMLInputElement;

        return {
          fullName: formData.get('fullName') as string,
          email: formData.get('email') as string,
          company: formData.get('company') as string,
          role: formData.get('role') as string,
          linkedin: formData.get('linkedin') as string,
          interestedInSponsoring: interestedInSponsoringCheckbox?.checked || false,
        };
      }

      showLoader() {
        const button = this.querySelector('button[type="submit"]') as HTMLButtonElement;
        const originalText = button.textContent;
        button.textContent = 'Submitting...';
        button.disabled = true;
      }

      hideLoader() {
        const button = this.querySelector('button[type="submit"]') as HTMLButtonElement;
        button.textContent = 'Register Interest';
        button.disabled = false;
      }

      showSuccess() {
        window.location.href = '/founder-film-club/complete';
      }
    },
  );


