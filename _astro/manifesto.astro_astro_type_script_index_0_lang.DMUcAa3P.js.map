  import gsap from 'gsap';
  import SplitText from 'gsap/SplitText';

  gsap.registerPlugin(SplitText);

  function createStaggeredHeaderFadeIn() {
    const title = document.getElementById('manifestoHeroTitle');
    if (!title) return null;
    const titleSplit = SplitText.create(title, { type: 'words,chars' });
    gsap.set(title, { opacity: 1 });
    gsap.set(titleSplit.chars, {
      opacity: 0,
      y: window.innerHeight * 0.04,
      filter: 'blur(8px)',
    });

    return gsap.to(titleSplit.chars, {
      opacity: 1,
      y: 0,
      filter: 'blur(0px)',
      duration: 0.5,
      ease: 'power2.out',
      stagger: 0.03,
    });
  }

  function animateManifestoLoad() {
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const heroTitle = document.getElementById('manifestoHeroTitle');
    const heroBadge = document.querySelector('.hero .badge, .hero > *:first-child');
    const sections = gsap.utils.toArray('.manifestoSection, .ctaSection');

    if (prefersReducedMotion) {
      gsap.set([heroTitle, heroBadge, sections], {
        opacity: 1,
        y: 0,
        filter: 'blur(0px)',
      });
      return;
    }

    const vh = window.innerHeight;
    const timeline = gsap.timeline();

    gsap.set(heroBadge, { opacity: 0, y: vh * 0.03 });
    gsap.set(sections, { opacity: 0, y: vh * 0.05, filter: 'blur(8px)' });

    timeline.to(
      heroBadge,
      {
        opacity: 1,
        y: 0,
        duration: 0.45,
        ease: 'power2.out',
      },
      0,
    );

    const titleAnimation = createStaggeredHeaderFadeIn();
    if (titleAnimation) {
      timeline.add(titleAnimation, '<+0.05');
    }

    timeline.to(
      sections,
      {
        opacity: 1,
        y: 0,
        filter: 'blur(0px)',
        duration: 0.6,
        ease: 'power2.out',
        stagger: 0.12,
      },
      '-=0.5',
    );
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', animateManifestoLoad, { once: true });
  } else {
    animateManifestoLoad();
  }


