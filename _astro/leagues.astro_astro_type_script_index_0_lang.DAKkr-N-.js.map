      const { default: gsap } = await import('gsap');
      const logos = this.querySelectorAll('.league-content li img');

      gsap.timeline({ defaults: { ease: 'power2.out' } }).to(logos, {
        opacity: 1,
        filter: 'blur(0px)',
        duration: 0.6,
        stagger: 0.12,
