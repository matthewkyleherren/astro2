        return;
      }

      // Store the original number of children before cloning
      const originalChildCount = leagueContent.children.length;
      league.style.setProperty('--league-elements', originalChildCount.toString());

      // Clone ALL original elements to create seamless loop
      const originalItems = Array.from(leagueContent.children).slice(0, originalChildCount);
      for (const item of originalItems) {
        const clone = item.cloneNode(true) as HTMLElement;
        clone.setAttribute('aria-hidden', 'true');
        // Ensure cloned logos are visible (they weren't part of entrance animation)
        const clonedImg = clone.querySelector('img') as HTMLElement;
        if (clonedImg) {
          clonedImg.style.opacity = '1';
          clonedImg.style.filter = 'blur(0px)';
