  import { sessionKeys } from '@utils/constants';
  const SEVEN_DAYS = 7 * 24 * 60 * 60;

  customElements.define(
    'country-input',
    class CountryInput extends HTMLElement {
      form: HTMLFormElement;
      constructor() {
        super();
        this.initializeCountrySelect();

        this.form = this.querySelector('form') as HTMLFormElement;
      }

      initializeCountrySelect() {
        const button = this.querySelector('#countryButton');
        const dropdown = this.querySelector('#countryDropdown');
        const hiddenInput = this.querySelector('#countryOfResidence') as HTMLInputElement;
        const searchInput = this.querySelector('#countrySearch') as HTMLInputElement;
        const countryOptions = this.querySelectorAll('.country-option');
        const radioButtons = this.querySelectorAll(
          'input[type="radio"]',
        ) as NodeListOf<HTMLInputElement>;

        if (!button || !dropdown || !hiddenInput || !searchInput) {
          console.error('Required elements not found');
          return;
        }

        button.addEventListener('click', (e) => {
          e.stopPropagation();
          dropdown.classList.toggle('hidden');
          if (!dropdown.classList.contains('hidden')) {
            searchInput.focus();
          }
        });

        const existingCountry = document.cookie
          .split('; ')
          .find((row) => row.startsWith(`${sessionKeys.countryOfResidence}=`))
          ?.split('=')[1];

        if (existingCountry) {
          const selectedOption = this.querySelector(
            `[data-value="${existingCountry.toLowerCase()}"]`,
          );
          if (selectedOption) {
            const text = selectedOption.querySelector('span')?.textContent;
            const img = selectedOption.querySelector('img')?.cloneNode(true);

            const buttonContent = button.querySelector('.flex');
            const textElement = buttonContent?.querySelector('p');

            if (textElement) {
              textElement.innerHTML = '';
              textElement.classList.add('flex', 'items-center', 'gap-2');
              if (img) textElement.appendChild(img);
              if (text) textElement.appendChild(document.createTextNode(` ${text}`));
              textElement.classList.remove('text-lightGrey');
            }

            hiddenInput.value = existingCountry.toLowerCase();
          }
        }

        searchInput.addEventListener('input', (e) => {
          const searchTerm = (e.target as HTMLInputElement).value.toLowerCase();
          countryOptions.forEach((option) => {
            const countryName = option.getAttribute('data-name') || '';
            const element = option as HTMLElement;
            element.style.display = countryName.includes(searchTerm) ? 'flex' : 'none';
          });
        });

        dropdown.addEventListener('click', (e) => {
          if (e.target instanceof HTMLInputElement) {
            localStorage.setItem('countryOfResidence', e.target.value);
          }
          const target = e.target as HTMLElement;
          const option = target.closest('.country-option');
          if (option) {
            const value = option.getAttribute('data-value');
            const text = option.querySelector('span')?.textContent;
            const img = option.querySelector('img')?.cloneNode(true);

            const buttonContent = button.querySelector('.flex');
            const textElement = buttonContent?.querySelector('p');

            if (textElement) {
              textElement.innerHTML = '';
              textElement.classList.add('flex', 'items-center', 'gap-2');
              if (img) textElement.appendChild(img);
              if (text) textElement.appendChild(document.createTextNode(` ${text}`));
              textElement.classList.remove('text-lightGrey');
            }

            if (value) {
              hiddenInput.value = value;
              document.cookie = `${sessionKeys.countryOfResidence}=${value}; path=/; max-age=${SEVEN_DAYS}`;
              hiddenInput.classList.remove('border-red-600');
              const errorElement = this.querySelector('[data-error-for="countryOfResidence"]');
              if (errorElement) errorElement.classList.add('opacity-0');
              radioButtons.forEach((radio) => (radio.checked = false));
            }

            dropdown.classList.add('hidden');
            searchInput.value = '';
            countryOptions.forEach((opt) => {
              (opt as HTMLElement).style.display = 'flex';
            });
          }
        });

        document.addEventListener('click', (e) => {
          if (!dropdown.contains(e.target as Node) && !button.contains(e.target as Node)) {
            dropdown.classList.add('hidden');
            searchInput.value = '';
            countryOptions.forEach((option) => {
              (option as HTMLElement).style.display = 'flex';
            });
          }
        });

        searchInput.addEventListener('click', (e) => {
          e.stopPropagation();
        });
      }
    },
  );


